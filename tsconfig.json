{
  "files": [
    "installed-tests/js/testGlobal.js",
    "installed-tests/js/testself.js",
    "modules/internal/internalLoader.js",
    "modules/internal/loader.js",
  ],
  "include": ["./types/gjs.d.ts"],
  "compilerOptions": {
    "noEmit": true,  // don't generate files, just typecheck them
    "allowJs": true,
    "checkJs": true,

    "target": "es2023",
    "lib": ["es2023"],
    // Consider splitting this into a separate tsconfig project for only the
    // test files, so that Jasmine types don't get pulled in globally.
    "types": ["jasmine"],

    // Path options
    "typeRoots": ["./tools/node_modules/@types"],

    // Type checking options
    "strict": true
  }
}
